# =============================================================================
# doe_downloaders — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# Unit test / coverage
.pytest_cache/
.coverage
htmlcov/
*.cover
.tox/
.nox/

# Type checking
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------

# Downloaded raw data files (can be large; reproduced by running the pipeline)
data/nevada/raw/
data/massachusetts/raw/

# Cleaned output CSVs (derived artifacts; regenerated by cleaners)
data/nevada/cleaned/
data/massachusetts/cleaned/

# Logs (generated at runtime)
logs/pipeline.log
logs/download_manifest.csv
logs/*.log
logs/*.csv

# Jupyter notebook checkpoints
notebooks/.ipynb_checkpoints/
.ipynb_checkpoints/

# Secrets / credentials (if ever added)
.env
*.env
secrets.py
credentials.json

# -----------------------------------------------------------------------------
# OS / Editor
# -----------------------------------------------------------------------------

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, etc.)
.idea/
*.iml

# Vim / Emacs swap files
*.swp
*.swo
*~
\#*\#
